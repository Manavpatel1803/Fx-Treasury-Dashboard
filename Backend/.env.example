DATABASE_URL=sqlite:///./fx_dashboard.db

# Market data: "twelvedata" for real intraday rates, or "frankfurter" (daily ECB, free, no key).
MARKET_DATA_PROVIDER=frankfurter
FX_API_BASE_URL=https://api.frankfurter.dev/v1
TWELVE_DATA_API_KEY=
TWELVE_DATA_BASE_URL=https://api.twelvedata.com

DEFAULT_PAIRS=GBP/USD,EUR/USD,USD/INR,EUR/GBP
SNAPSHOT_INTERVAL_MINUTES=60
ALERT_THRESHOLD_PERCENT=1.0
FRONTEND_ORIGIN=http://localhost:5173

# LLM for "why did it move" explanations. Provider: "gemini" (free) or "anthropic".
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
